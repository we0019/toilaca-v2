---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import runningData from "@/data/running/activities.json";

type RunningActivity = {
  id: string;
  title: string;
  startDate: string;
  distanceKm: number | null;
  durationSeconds: number | null;
  paceSecondsPerKm: number | null;
  elevationGainMeters: number | null;
  averageHeartRate: number | null;
  trainingLoad: number | null;
  url: string | null;
};

const activities = runningData.activities as RunningActivity[];
const recentActivities = activities.slice(0, 10);
const totalDistance = activities.reduce(
  (sum, activity) => sum + (activity.distanceKm ?? 0),
  0
);
const totalDuration = activities.reduce(
  (sum, activity) => sum + (activity.durationSeconds ?? 0),
  0
);
const averagePace =
  totalDistance > 0 && totalDuration > 0
    ? Math.round(totalDuration / totalDistance)
    : null;
const latestActivity = activities[0];
const lastSyncedAt = runningData.lastSyncedAt
  ? formatDateTime(runningData.lastSyncedAt)
  : null;

const weeklyDistance = getRecentWeeklyDistance(activities);
const maxWeeklyDistance = Math.max(
  1,
  ...weeklyDistance.map(week => week.distanceKm)
);

const stats = [
  {
    label: "Tổng quãng đường",
    value: `${totalDistance.toFixed(1)} km`,
  },
  {
    label: "Số buổi chạy",
    value: String(activities.length),
  },
  {
    label: "Pace trung bình",
    value: formatPace(averagePace),
  },
  {
    label: "Buổi mới nhất",
    value: latestActivity ? formatDate(latestActivity.startDate) : "-",
  },
];

function formatDate(date: string) {
  return new Intl.DateTimeFormat("vi-VN", {
    day: "2-digit",
    month: "2-digit",
    year: "numeric",
  }).format(new Date(date));
}

function formatDateTime(date: string) {
  return new Intl.DateTimeFormat("vi-VN", {
    day: "2-digit",
    month: "2-digit",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  }).format(new Date(date));
}

function formatDuration(seconds: number | null) {
  if (!seconds) return "-";

  const hours = Math.floor(seconds / 3600);
  const minutes = Math.floor((seconds % 3600) / 60);

  return hours > 0 ? `${hours}g ${minutes}p` : `${minutes}p`;
}

function formatPace(seconds: number | null) {
  if (!seconds) return "-";

  const minutes = Math.floor(seconds / 60);
  const restSeconds = String(seconds % 60).padStart(2, "0");

  return `${minutes}:${restSeconds}/km`;
}

function getRecentWeeklyDistance(source: RunningActivity[]) {
  const latestDate = source[0]?.startDate
    ? new Date(source[0].startDate)
    : new Date();
  const latestMonday = getMonday(latestDate);
  const weeks = Array.from({ length: 8 }, (_, index) => {
    const date = new Date(latestMonday);
    date.setDate(date.getDate() - (7 - index) * 7);
    return {
      key: date.toISOString().slice(0, 10),
      label: `${date.getDate()}/${date.getMonth() + 1}`,
      distanceKm: 0,
    };
  });
  const weeksByKey = new Map(weeks.map(week => [week.key, week]));

  source.forEach(activity => {
    const date = new Date(activity.startDate);
    if (Number.isNaN(date.getTime())) return;

    const key = getMonday(date).toISOString().slice(0, 10);
    const week = weeksByKey.get(key);
    if (!week) return;

    week.distanceKm += activity.distanceKm ?? 0;
  });

  return weeks.map(week => ({
    ...week,
    distanceKm: Math.round(week.distanceKm * 10) / 10,
  }));
}

function getMonday(date: Date) {
  const monday = new Date(date);
  const day = (monday.getDay() + 6) % 7;
  monday.setDate(monday.getDate() - day);
  monday.setHours(0, 0, 0, 0);
  return monday;
}
---

<Layout title="Chạy bộ" description="Nhật ký chạy bộ tự đồng bộ từ Garmin.">
  <Header />
  <main id="main-content" class="app-layout py-10">
    <section class="pb-8">
      <p class="text-accent text-sm font-semibold tracking-wide uppercase">
        Đồng bộ tự động
      </p>
      <div
        class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between"
      >
        <div>
          <h1 class="text-3xl font-semibold sm:text-4xl">Chạy bộ</h1>
          <p class="text-muted-foreground mt-3 max-w-2xl leading-7">
            Dữ liệu được lấy từ Garmin thông qua Intervals.icu, rồi tự cập nhật
            lên site bằng GitHub Actions.
          </p>
        </div>
        {
          lastSyncedAt && (
            <p class="text-muted-foreground text-sm whitespace-nowrap">
              Cập nhật: {lastSyncedAt}
            </p>
          )
        }
      </div>
    </section>

    <section
      class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4"
      aria-label="Thống kê chạy bộ"
    >
      {
        stats.map(stat => (
          <div class="border-border bg-muted/20 rounded-md border px-4 py-4">
            <p class="text-muted-foreground text-sm">{stat.label}</p>
            <p class="mt-2 text-2xl font-semibold">{stat.value}</p>
          </div>
        ))
      }
    </section>

    {
      weeklyDistance.length > 0 && (
        <section class="border-border mt-10 border-t pt-8">
          <div class="flex items-baseline justify-between gap-4">
            <h2 class="text-xl font-semibold">8 tuần gần đây</h2>
            <p class="text-muted-foreground text-sm">km mỗi tuần</p>
          </div>
          <div class="mt-6 grid h-52 grid-cols-8 items-end gap-2 sm:gap-3">
            {weeklyDistance.map(week => (
              <div class="flex h-full flex-col justify-end gap-2">
                <p class="text-muted-foreground text-center text-xs">
                  {week.distanceKm > 0 ? week.distanceKm : ""}
                </p>
                <div
                  class="bg-accent min-h-1 w-full rounded-t-sm"
                  style={`height: ${Math.max(
                    4,
                    (week.distanceKm / maxWeeklyDistance) * 100
                  )}%`}
                  title={`${week.distanceKm} km`}
                />
                <p class="text-muted-foreground text-center text-xs">
                  {week.label}
                </p>
              </div>
            ))}
          </div>
        </section>
      )
    }

    <section class="border-border mt-10 border-t pt-8">
      <div class="flex items-baseline justify-between gap-4">
        <h2 class="text-xl font-semibold">Hoạt động gần đây</h2>
        <p class="text-muted-foreground text-sm">
          {
            recentActivities.length > 0
              ? `${recentActivities.length} buổi mới nhất`
              : ""
          }
        </p>
      </div>
      {
        recentActivities.length > 0 ? (
          <ul class="mt-4 space-y-3">
            {recentActivities.map(activity => (
              <li class="border-border bg-muted/15 rounded-md border p-4">
                <a
                  href={activity.url ?? "#"}
                  class="hover:text-accent block font-semibold"
                  target="_blank"
                  rel="noreferrer"
                >
                  {activity.title}
                </a>
                <dl class="mt-3 grid grid-cols-2 gap-3 text-sm sm:grid-cols-5">
                  <div>
                    <dt class="text-muted-foreground">Ngày</dt>
                    <dd class="mt-1">{formatDate(activity.startDate)}</dd>
                  </div>
                  <div>
                    <dt class="text-muted-foreground">Quãng đường</dt>
                    <dd class="mt-1">
                      {activity.distanceKm?.toFixed(2) ?? "-"} km
                    </dd>
                  </div>
                  <div>
                    <dt class="text-muted-foreground">Thời gian</dt>
                    <dd class="mt-1">
                      {formatDuration(activity.durationSeconds)}
                    </dd>
                  </div>
                  <div>
                    <dt class="text-muted-foreground">Pace</dt>
                    <dd class="mt-1">
                      {formatPace(activity.paceSecondsPerKm)}
                    </dd>
                  </div>
                  <div>
                    <dt class="text-muted-foreground">Tim TB</dt>
                    <dd class="mt-1">
                      {activity.averageHeartRate
                        ? `${Math.round(activity.averageHeartRate)} bpm`
                        : "-"}
                    </dd>
                  </div>
                </dl>
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-muted-foreground mt-4 leading-7">
            Chưa có dữ liệu chạy bộ. Sau khi Intervals.icu đồng bộ Garmin và
            workflow chạy lần đầu, dữ liệu sẽ xuất hiện ở đây.
          </p>
        )
      }
    </section>
  </main>
  <Footer />
</Layout>
