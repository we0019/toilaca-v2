{
  "name": "toilaca-v2",
  "type": "module",
  "version": "6.1.0",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build && pagefind --site dist && node -e \"require('fs').cpSync('dist/pagefind','public/pagefind',{recursive:true,force:true})\"",
    "preview": "astro preview",
    "sync": "astro sync",
    "sync:intervals": "node scripts/sync-intervals.mjs",
    "astro": "astro",
    "format:check": "prettier --check \"*.{js,json,ts,yaml}\" \".github/workflows/*.yml\" \"scripts/**/*.mjs\" \"src/*.ts\" \"src/components/**/*.astro\" \"src/layouts/**/*.astro\" \"src/pages/**/*.{astro,ts}\" \"src/styles/**/*.css\" \"src/utils/**/*.{js,ts}\" \"src/scripts/**/*.ts\" \"src/types/**/*.ts\" \"src/data/**/*.json\" \"src/content/pages/**/*.md\" \"src/content/posts/*.md\"",
    "format": "prettier --write \"*.{js,json,ts,yaml}\" \".github/workflows/*.yml\" \"scripts/**/*.mjs\" \"src/*.ts\" \"src/components/**/*.astro\" \"src/layouts/**/*.astro\" \"src/pages/**/*.{astro,ts}\" \"src/styles/**/*.css\" \"src/utils/**/*.{js,ts}\" \"src/scripts/**/*.ts\" \"src/types/**/*.ts\" \"src/data/**/*.json\" \"src/content/pages/**/*.md\" \"src/content/posts/*.md\"",
    "lint": "eslint ."
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.3",
    "dayjs": "^1.11.21",
    "lodash.kebabcase": "^4.1.1",
    "@astrojs/markdown-remark": "^7.2.0",
    "rehype-callouts": "^2.2.0",
    "remark-collapse": "^0.1.2",
    "remark-toc": "^9.0.0",
    "satori": "^0.26.0",
    "sharp": "^0.35.2",
    "slugify": "^1.6.9",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@pagefind/default-ui": "^1.5.2",
    "@shikijs/transformers": "^4.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/lodash.kebabcase": "^4.1.9",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "pagefind": "^1.5.2",
    "prettier": "3.9.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3"
  }
}
